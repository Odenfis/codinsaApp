# =============================================================================
# Tool Kit Enterprise - Variables de Entorno (Cliente Windows)
# Copiar como .env en el servidor del cliente
# =============================================================================
# Este archivo nunca se sube al repositorio. Solo existe en el servidor.
# =============================================================================

# SESSION_SECRET: Clave para firma de cookies de sesión (cambiar por una segura)
SESSION_SECRET=ToolKit_SecureKey_2026_Enterprise

# Credenciales SQL Server 2022 nativo (Windows)
DB_SERVER=host.docker.internal,1433
DB_USER=Coinsa
DB_PASSWORD=2026
DB_NAME=COINSA

# API RUC para asignación masiva de ubigeos
API_RUC_TOKEN=tu_token_aqui
